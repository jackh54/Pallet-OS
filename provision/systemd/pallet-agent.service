[Unit]
Description=Pallet OS management agent
After=network-online.target pallet-wifi.service NetworkManager.service
Wants=network-online.target pallet-wifi.service

[Service]
Type=simple
ExecStart=/usr/local/bin/pallet-agent -config /etc/pallet/agent.json
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target

#!/usr/bin/env bash
# Simple lock overlay helper invoked by pallet-agent
set -euo pipefail
STATE_DIR="/run/pallet"
LOCK_FILE="$STATE_DIR/locked"
mkdir -p "$STATE_DIR"
case "${1:-}" in
  --enable)
    touch "$LOCK_FILE"
    loginctl lock-sessions 2>/dev/null || true
    ;;
  --disable)
    rm -f "$LOCK_FILE"
    loginctl unlock-sessions 2>/dev/null || true
    ;;
  *)
    echo "Usage: $0 --enable|--disable"
    exit 1
    ;;
esac
